include global.pug

doctype html
html(lang="pt-br")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel="stylesheet", href="assets/styles/css/index.css")
        title CodeAlly - Transforme bugs em sucesso.
    body
        header.header#header
            a.header-logo(href="#") code
                span ally
            .header-auth
                a.auth-link(href="#") Login
                a.auth-link(href="#") Cadastro
        main.main#main
            section.home.section#home
                .home-content 
                    h1.home-title 
                        |Transforme bugs em 
                        span sucesso
                        |.
                    h3.home-subtitle 
                        |Ajudamos empresas e programadores a economizar 
                        span tempo 
                        |e 
                        span dinheiro
                        |. Encontre freelancers experientes e altamente qualificados.
                    button.home-button Começar agora
                    .home-card
                        .home-item
                            svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24")

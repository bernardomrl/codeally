                            .item-text
                                h1.item-title 20+
                                h3.item-subtitle Servidores 
            section.security.section#security
                .security-content
                    .security-svg
                        embed(src="assets/images/svg/index/security/security.svg", type="image/svg+xml")
                    .security-text
                        h1.security-title 
                            |Nós oferecemos 
                            span toda 
                            |a segurança para você.
                        h3.security-subtitle Você pode explorar os recursos que fornecemos com segurança, qualidade e confiança.
                        ul.security-list
                            li.security-item
                                +check-circle
                                p.item-text Políticas de privacidade e segurança.
                            li.security-item
                                +check-circle
                                p.item-text Garantias de políticas de devolução.
                            li.security-item
                                +check-circle
                                p.item-text Atendimento eficiente ao cliente.
                            li.security-item
                                +check-circle
                                p.item-text Certificações e parcerias.
            section.plans.section#plans
                h1.plans-title Escolha seu plano
                h3.plans-subtitle Vamos escolher o pacote que mais combina com você.
                .plans-content
                    .plan
                        .plan-svg
                            embed(src="assets/images/svg/index/plans/basic.svg", type="image/svg+xml")
                        h1.plan-title Plano Básico
                        ul.plan-features
                            li.plan-feature
                                +check-circle
                                p.feature-text Registro de conta básica para clientes e freelancers.
                            li.plan-feature
                                +check-circle
                                p.feature-text Limite de 1 projeto ativo por vez.
                            li.plan-feature
                                +check-circle
                                p.feature-text Acesso limitado a freelancers iniciantes.
                        .plan-price
                            h1.price-text Gratuito
                            button.price-button Selecionar
                    .plan
                        .plan-svg
                            embed(src="assets/images/svg/index/plans/pro.svg", type="image/svg+xml")
                        h1.plan-title Plano Pro
                        ul.plan-features
                            li.plan-feature
                                +check-circle
                                p.feature-text Todos os recursos do plano básico.
                            li.plan-feature
                                +check-circle
                                p.feature-text Limite de 4 projetos ativos simultaneamente.
                            li.plan-feature
                                +check-circle
                                p.feature-text Acesso a freelancers qualificados e com experiência comprovada.
                            li.plan-feature
                                +check-circle
                                p.feature-text Tempos de resposta mais rápidos.
                        .plan-price
                            h1.price-text R$16 
                                span / mês
                            button.price-button Selecionar
                    .plan
                        .plan-svg
                            embed(src="assets/images/svg/index/plans/premium.svg", type="image/svg+xml")
                        h1.plan-title Plano Premium
                        ul.plan-features
                            li.plan-feature
                                +check-circle
                                p.feature-text Todos os recursos do plano pro.
                            li.plan-feature
                                +check-circle
                                p.feature-text Acesso a uma seleção exclusiva de freelancers de alto nível.
                            li.plan-feature
                                +check-circle
                                p.feature-text Destaque de projetos para obter maior visibilidade.
                            li.plan-feature
                                +check-circle
                                p.feature-text Prioridade na atribuição de freelancers e resposta rápida.
                            li.plan-feature
                                +check-circle
                                p.feature-text Possibilidade de contratar freelancers em regime de exclusividade.
                        .plan-price
                            h1.price-text R$28 
                                span / mês
                            button.price-button Selecionar
